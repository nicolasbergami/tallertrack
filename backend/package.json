{
  "name": "tallertrack-api",
  "version": "1.0.0",
  "description": "TallerTrack REST API — Backend for workshop management SaaS",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/scripts/migrate.js && node dist/server.js",
    "migrate": "node dist/scripts/migrate.js",
    "migrate:dev": "tsx src/scripts/migrate.ts",
    "seed": "node dist/scripts/seed.js",
    "seed:dev": "tsx src/scripts/seed.ts",
    "lint": "eslint src --ext .ts",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@hapi/boom": "^10.0.1",
    "@types/pdfkit": "^0.17.5",
    "@whiskeysockets/baileys": "^6.7.21",
    "bcrypt": "^6.0.0",
    "cloudinary": "^1.41.3",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "multer-storage-cloudinary": "^4.0.0",
    "openai": "^6.32.0",
    "pdfkit": "^0.18.0",
    "pg": "^8.12.0",
    "qrcode": "^1.5.4",
    "resend": "^6.9.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.6",
    "@types/qrcode": "^1.5.5",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "tsx": "^4.15.7",
    "typescript": "^5.5.2",
    "vitest": "^1.6.0"
  }
}
