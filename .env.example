# ─────────────────────────────────────────────────────────────────────────────
# TallerTrack — Environment Variables
# Copy this file to .env and fill in your values.
# In Railway, set these directly in the service Variables tab.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# Railway injects ${{RAILWAY_PUBLIC_DOMAIN}} automatically — use it here:
# BASE_URL=https://<your-app>.up.railway.app
BASE_URL=https://your-app.up.railway.app

# ── Database ─────────────────────────────────────────────────────────────────
# Railway PostgreSQL plugin injects DATABASE_URL automatically.
# If using Railway Postgres, just add the plugin and this is set for you.
DATABASE_URL=postgresql://user:password@host:5432/railway

# ── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-64-char-string-in-production
JWT_EXPIRES_IN=8h

# ── Public tracking URL ──────────────────────────────────────────────────────
# This is the URL printed on QR codes handed to customers.
# Usually the same as BASE_URL.
TRACKING_BASE_URL=https://your-app.up.railway.app

# ── AI Features (Anthropic Claude) ───────────────────────────────────────────
# Required for: voice quote extraction, delivery prediction.
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── WhatsApp (optional) ──────────────────────────────────────────────────────
# WHATSAPP_PROVIDER=mock   → logs messages to console (default, free)
# WHATSAPP_PROVIDER=meta   → sends real WhatsApp messages via Meta Cloud API
WHATSAPP_PROVIDER=mock
# WHATSAPP_API_URL=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_TEMPLATE_NAMESPACE=
