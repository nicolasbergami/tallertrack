# Server
PORT=3000
NODE_ENV=development
BASE_URL=http://localhost:3000

# PostgreSQL
DATABASE_URL=postgresql://tallertrack_app:CHANGE_ME@localhost:5432/tallertrack

# JWT
JWT_SECRET=super-secret-key-change-in-production
JWT_EXPIRES_IN=8h

# Public tracking URL (used in QR codes)
TRACKING_BASE_URL=https://track.tallertrack.com

# WhatsApp (Meta Cloud API or Twilio Sandbox)
# Set WHATSAPP_PROVIDER=mock for local dev
WHATSAPP_PROVIDER=mock
WHATSAPP_API_URL=https://graph.facebook.com/v19.0
WHATSAPP_PHONE_NUMBER_ID=YOUR_PHONE_NUMBER_ID
WHATSAPP_ACCESS_TOKEN=YOUR_ACCESS_TOKEN
WHATSAPP_TEMPLATE_NAMESPACE=YOUR_TEMPLATE_NAMESPACE
